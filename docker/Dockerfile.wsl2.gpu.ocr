FROM rl-engram:gpu

WORKDIR /workspace

RUN apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    tesseract-ocr \
    tesseract-ocr-eng \
    poppler-utils \
    && rm -rf /var/lib/apt/lists/*

RUN python -m pip install --break-system-packages \
    pymupdf \
    pypdf \
    pillow \
    pytesseract \
    datasets \
    rapidfuzz
